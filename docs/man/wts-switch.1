.nh
.TH "WORKSWITCH" "1" "Mar 2026" "workswitch" "workswitch Manual"

.SH NAME
wts-switch - Switch to a worktree


.SH SYNOPSIS
\fBwts switch  [flags]\fP


.SH DESCRIPTION
Switch to a worktree


.SH OPTIONS
\fB--attach\fP[=false]
	attach/focus tmux after command

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for switch


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	path to .wts.yaml

.PP
\fB--state\fP=""
	path to state file (default ~/.workswitch/state.yaml)


.SH SEE ALSO
\fBwts(1)\fP
