.nh
.TH "WORKSWITCH" "1" "Mar 2026" "workswitch" "workswitch Manual"

.SH NAME
wts-switch - Switch active workspace within its group


.SH SYNOPSIS
\fBwts switch  [flags]\fP


.SH DESCRIPTION
Activate a workspace with group preemption semantics.

.PP
Behavior:
- if another workspace is active in the same group, it is stopped first
- if target workspace is already running, it is reused
- marks the target as active for its group


.SH OPTIONS
\fB--attach\fP[=false]
	attach/focus tmux after switching

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for switch


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	path to .wts.yaml (legacy: .worktreeswitch.yaml/.workswitch.yaml)


.SH EXAMPLE
.EX
  wts switch api-main
  wts switch api-agent-b --attach
.EE


.SH SEE ALSO
\fBwts(1)\fP
