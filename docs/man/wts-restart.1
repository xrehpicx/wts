.nh
.TH "WORKSWITCH" "1" "Mar 2026" "workswitch" "workswitch Manual"

.SH NAME
wts-restart - Restart process in a worktree


.SH SYNOPSIS
\fBwts restart  [flags]\fP


.SH DESCRIPTION
Start or move a process profile to a target worktree.

.PP
The currently active worktree process is stopped first, then the target process
is started in the selected worktree directory.


.SH OPTIONS
\fB--attach\fP[=false]
	attach/focus tmux after command

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for restart

.PP
\fB--process\fP=""
	process profile name (default: first process in config)


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	path to .wts.yaml


.SH EXAMPLE
.EX
wts restart repo-main
  wts restart ../repo-agent --process demo-script
  wts restart /abs/path/to/worktree --attach
.EE


.SH SEE ALSO
\fBwts(1)\fP
