.nh
.TH "WORKSWITCH" "1" "Mar 2026" "workswitch" "workswitch Manual"

.SH NAME
wts - workswitch (wts: worktree switch) process handoff for git worktrees


.SH SYNOPSIS
\fBwts [flags]\fP


.SH DESCRIPTION
Process config lives in .wts.yaml.
Worktrees are discovered live from: git worktree list --porcelain.

.PP
Switching preempts the previously active worktree process and starts the selected
process in the target worktree.


.SH OPTIONS
\fB--config\fP=""
	path to .wts.yaml

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for wts


.SH EXAMPLE
.EX
wts validate
  wts list
  wts switch repo-main --process api
  wts next --process demo-script
  wts status --json
  wts tui
.EE


.SH SEE ALSO
\fBwts-init(1)\fP, \fBwts-list(1)\fP, \fBwts-logs(1)\fP, \fBwts-next(1)\fP, \fBwts-pick(1)\fP, \fBwts-prev(1)\fP, \fBwts-processes(1)\fP, \fBwts-restart(1)\fP, \fBwts-start(1)\fP, \fBwts-status(1)\fP, \fBwts-stop(1)\fP, \fBwts-switch(1)\fP, \fBwts-tui(1)\fP, \fBwts-validate(1)\fP, \fBwts-version(1)\fP
