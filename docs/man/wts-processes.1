.nh
.TH "WORKSWITCH" "1" "Mar 2026" "workswitch" "workswitch Manual"

.SH NAME
wts-processes - List process profiles and groups from config


.SH SYNOPSIS
\fBwts processes [flags]\fP


.SH DESCRIPTION
Show process profile commands and configured process groups from .wts.yaml.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for processes


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--config\fP=""
	path to .wts.yaml


.SH EXAMPLE
.EX
wts processes
  wts processes --config ../other/.wts.yaml
.EE


.SH SEE ALSO
\fBwts(1)\fP
